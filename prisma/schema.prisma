generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum MatchStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELLED
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CouponReason {
  REGISTER
  INVITED_SOMEONE
}

// ============ Authentication & User Core ============

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  passwordHash      String?
  name              String
  age               Int?
  ageGroup          String?
  gender            Gender?
  bio               String?
  city              String?
  latitude          Float?
  longitude         Float?
  avatarUrl         String?
  isOnboarded       Boolean   @default(false)
  isActive          Boolean   @default(true)
  isBanned          Boolean   @default(false)
  banReason         String?
  role              Role      @default(USER)
  canCreateEvents   Boolean   @default(false)
  stripeCustomerId  String?   @unique
  subscriptionStatus SubscriptionStatus @default(FREE)
  subscriptionId    String?
  averageRating     Float?
  ratingCount       Int       @default(0)
  relationshipGoal  String?   // "SERIOUS" | "OPEN" | "FRIENDSHIP"
  smokingHabit      String?   // "NEVER" | "OCCASIONALLY" | "REGULARLY"
  drinkingHabit     String?   // "NEVER" | "OCCASIONALLY" | "REGULARLY"
  wantsChildren     String?   // "YES" | "NO" | "OPEN"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLocationUpdate DateTime?

  interests         UserInterest[]
  answers           QuestionnaireAnswer[]
  eventsCreated     Event[]              @relation("EventCreator")
  eventAttendances  EventAttendance[]
  matchMemberships  MatchMember[]
  ratingsGiven      Rating[]             @relation("RaterUser")
  ratingsReceived   Rating[]             @relation("RatedUser")
  reportsSubmitted  Report[]             @relation("ReportedBy")
  reportsAbout      Report[]             @relation("ReportedUser")
  blocksGiven       Block[]              @relation("Blocker")
  blocksReceived    Block[]              @relation("Blocked")
  messages          Message[]
  sentMessages      DirectMessage[]      @relation("SentMessages")
  receivedMessages  DirectMessage[]      @relation("ReceivedMessages")
  accounts          Account[]
  sessions          Session[]
  inviteCodesOwned  InviteCode[]     @relation("InviteCodeOwner")
  inviteCodeUsed    InviteCodeUsage? @relation("InviteCodeUsed")
  coupons           FreeCoupon[]     @relation("UserCoupons")

  @@index([email])
  @@index([city])
  @@index([isActive])
  @@index([isBanned])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ Interests & Onboarding ============

model Interest {
  id    String  @id @default(cuid())
  name  String  @unique
  icon  String?

  userInterests UserInterest[]
}

model UserInterest {
  userId     String
  interestId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
}

model QuestionnaireQuestion {
  id      String  @id @default(cuid())
  text    String
  type    String
  options String?
  weight  Float   @default(1.0)
  order   Int     @default(0)

  answers QuestionnaireAnswer[]

  @@index([order])
}

model QuestionnaireAnswer {
  id         String  @id @default(cuid())
  userId     String
  questionId String
  answer     String
  createdAt  DateTime @default(now())

  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QuestionnaireQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

// ============ Matching ============

model Match {
  id        String      @id @default(cuid())
  status    MatchStatus @default(PENDING)
  city      String
  ageGroup  String
  createdAt DateTime    @default(now())
  expiresAt DateTime

  members MatchMember[]
  event   Event?

  @@index([status])
  @@index([city])
  @@index([createdAt])
}

model MatchMember {
  matchId   String
  userId    String
  confirmed Boolean @default(false)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
  @@index([userId])
}

// ============ Events ============

model Event {
  id           String      @id @default(cuid())
  title        String
  description  String?
  type         String
  city         String
  address      String?
  latitude     Float?
  longitude    Float?
  imageUrl     String?
  date         DateTime
  maxAttendees Int         @default(6)
  priceAmount  Int         @default(0)
  priceCurrency String     @default("usd")
  status       EventStatus @default(UPCOMING)
  creatorId    String
  matchId      String?     @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  creator      User              @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  match        Match?            @relation(fields: [matchId], references: [id])
  attendances  EventAttendance[]
  messages     Message[]
  ratings      Rating[]
  reports      Report[]
  couponsUsed  FreeCoupon[]      @relation("EventCouponsUsed")

  @@index([status])
  @@index([city])
  @@index([date])
  @@index([creatorId])
  @@index([matchId])
}

model EventAttendance {
  eventId   String
  userId    String
  status    AttendanceStatus @default(PENDING)
  paidAt    DateTime?
  paymentId String?
  joinedAt  DateTime         @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
  @@index([status])
}

// ============ Chat & Messaging ============

model Message {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@index([createdAt])
}

model DirectMessage {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([isRead])
}

// ============ Ratings ============

model Rating {
  id          String   @id @default(cuid())
  eventId     String
  raterId     String
  ratedUserId String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())

  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rater      User  @relation("RaterUser", fields: [raterId], references: [id], onDelete: Cascade)
  ratedUser  User  @relation("RatedUser", fields: [ratedUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, raterId, ratedUserId])
  @@index([eventId])
  @@index([ratedUserId])
  @@index([createdAt])
}

// ============ Safety Features ============

model Report {
  id              String       @id @default(cuid())
  reportedById    String
  reportedUserId  String?
  reportedEventId String?
  reason          String
  description     String?
  status          ReportStatus @default(OPEN)
  adminNotes      String?
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())

  reportedBy    User   @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: Cascade)
  reportedUser  User?  @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedEvent Event? @relation(fields: [reportedEventId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([reportedUserId])
  @@index([createdAt])
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

// ============ Invite & Coupon System ============

model InviteCode {
  id         String   @id @default(cuid())
  code       String   @unique
  ownerId    String
  usageCount Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner  User             @relation("InviteCodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  usages InviteCodeUsage[]

  @@index([ownerId])
  @@index([code])
  @@index([isActive])
}

model InviteCodeUsage {
  id           String   @id @default(cuid())
  inviteCodeId String
  newUserId    String   @unique
  usedAt       DateTime @default(now())

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  newUser    User       @relation("InviteCodeUsed", fields: [newUserId], references: [id], onDelete: Cascade)

  @@index([inviteCodeId])
}

model FreeCoupon {
  id             String       @id @default(cuid())
  code           String       @unique
  userId         String
  welcomeText    String
  isUsed         Boolean      @default(false)
  usedAt         DateTime?
  usedForEventId String?
  expiresAt      DateTime
  reason         CouponReason
  createdAt      DateTime     @default(now())

  user         User   @relation("UserCoupons", fields: [userId], references: [id], onDelete: Cascade)
  usedForEvent Event? @relation("EventCouponsUsed", fields: [usedForEventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isUsed])
  @@index([expiresAt])
  @@index([code])
}
