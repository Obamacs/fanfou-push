{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.meal-meet.com"
        }
      ],
      "destination": "https://meal-meet.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/notify-events",
      "schedule": "*/15 * * * *"
    }
  ]
}
